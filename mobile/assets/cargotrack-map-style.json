{
  "version": 8,
  "name": "CargoTrack",
  "metadata": { "cargotrack:version": "1.0" },
  "sources": {
    "ofm": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "© OpenFreeMap contributors, © OpenStreetMap contributors"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprite/liberty",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#F5F3EF" } },

    { "id": "landuse-residential", "type": "fill", "source": "ofm", "source-layer": "landuse",
      "filter": ["in", "class", "residential", "commercial", "industrial", "retail"],
      "paint": { "fill-color": "#EBE8E2", "fill-opacity": 0.55 } },

    { "id": "landcover-grass", "type": "fill", "source": "ofm", "source-layer": "landcover",
      "filter": ["in", "class", "grass", "meadow", "farmland"],
      "paint": { "fill-color": "#E8F0E4", "fill-opacity": 0.5 } },

    { "id": "landcover-wood", "type": "fill", "source": "ofm", "source-layer": "landcover",
      "filter": ["in", "class", "wood", "forest", "scrub"],
      "paint": { "fill-color": "#D0E8C0", "fill-opacity": 0.55 } },

    { "id": "park", "type": "fill", "source": "ofm", "source-layer": "park",
      "paint": { "fill-color": "#DFF0D8", "fill-opacity": 0.7 } },

    { "id": "water", "type": "fill", "source": "ofm", "source-layer": "water",
      "paint": { "fill-color": "#C8DCF0" } },

    { "id": "waterway", "type": "line", "source": "ofm", "source-layer": "waterway",
      "paint": { "line-color": "#C8DCF0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2.5] } },

    { "id": "building", "type": "fill", "source": "ofm", "source-layer": "building",
      "minzoom": 14,
      "paint": { "fill-color": "#E4E0D8", "fill-outline-color": "#D4D0C8", "fill-opacity": 0.8 } },

    { "id": "road-path", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": { "line-color": "#EEEBE5", "line-width": 0.8 } },

    { "id": "road-service", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["==", "class", "service"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": { "line-color": "#FFFFFF", "line-width": 1 } },

    { "id": "road-minor", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["in", "class", "minor", "residential"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": { "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1, 16, 4] } },

    { "id": "road-tertiary", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["==", "class", "tertiary"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": { "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1.5, 16, 5] } },

    { "id": "road-secondary", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": { "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2, 16, 6] } },

    { "id": "road-primary", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": { "line-color": "#F9F7F4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 2.5, 16, 8] } },

    { "id": "road-motorway", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": { "line-color": "#F5F2ED",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 3, 16, 10] } },

    { "id": "ferry", "type": "line", "source": "ofm", "source-layer": "transportation",
      "filter": ["==", "class", "ferry"],
      "paint": { "line-color": "#C8DCF0", "line-width": 1.5, "line-dasharray": [5, 4] } },

    { "id": "boundary-country", "type": "line", "source": "ofm", "source-layer": "boundary",
      "filter": ["all", ["==", "admin_level", 2], ["!has", "maritime"]],
      "paint": { "line-color": "#C4B9A8", "line-width": 1.2, "line-dasharray": [3, 2] } },

    { "id": "boundary-state", "type": "line", "source": "ofm", "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": { "line-color": "#D4CCBF", "line-width": 0.7, "line-dasharray": [4, 3] } },

    { "id": "place-village", "type": "symbol", "source": "ofm", "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet", "suburb"],
      "minzoom": 11,
      "layout": { "text-field": "{name:en}", "text-font": ["Open Sans Regular"],
        "text-size": 10, "text-max-width": 7 },
      "paint": { "text-color": "#6B7280", "text-halo-color": "#F5F3EF", "text-halo-width": 1 } },

    { "id": "place-town", "type": "symbol", "source": "ofm", "source-layer": "place",
      "filter": ["==", "class", "town"],
      "minzoom": 8,
      "layout": { "text-field": "{name:en}", "text-font": ["Open Sans Regular"],
        "text-size": 12, "text-max-width": 8 },
      "paint": { "text-color": "#374151", "text-halo-color": "#F5F3EF", "text-halo-width": 1.5 } },

    { "id": "place-city", "type": "symbol", "source": "ofm", "source-layer": "place",
      "filter": ["in", "class", "city"],
      "minzoom": 4,
      "layout": { "text-field": "{name:en}", "text-font": ["Open Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 11, 10, 15],
        "text-max-width": 8, "icon-allow-overlap": false },
      "paint": { "text-color": "#1F2937", "text-halo-color": "#F5F3EF", "text-halo-width": 2 } },

    { "id": "country-label", "type": "symbol", "source": "ofm", "source-layer": "place",
      "filter": ["==", "class", "country"],
      "minzoom": 3,
      "layout": { "text-field": "{name:en}", "text-font": ["Open Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 12, 8, 18],
        "text-transform": "uppercase", "text-letter-spacing": 0.12, "text-max-width": 10 },
      "paint": { "text-color": "#374151", "text-halo-color": "#F5F3EF", "text-halo-width": 2 } }
  ]
}
