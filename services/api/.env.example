# CargoTrack — Environment Variables
# Copy this file to .env and fill in real values before running locally or deploying.
# Never commit .env to version control.

# ── Django core ───────────────────────────────────────────────────────────────

# Set to True only in local development. Always False in production.
DEBUG=True

# Generate a strong random key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-me-in-production

# Comma-separated list of hostnames Django will serve.
# Example production value: cargotrack.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of origins allowed to make cross-site requests.
# Development: Vite dev server. Production: your frontend domain.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Email ─────────────────────────────────────────────────────────────────────

# Development: console backend prints emails to stdout (no SMTP needed).
# Production: switch to django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@cargotrack.example.com
EMAIL_HOST_PASSWORD=replace-me
DEFAULT_FROM_EMAIL=CargoTrack <noreply@cargotrack.example.com>

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────

DB_NAME=cargotrack
DB_USER=postgres
# IMPORTANT: Set a strong unique password here. Never commit .env to git.
# Verify with: git ls-files .env  (should return nothing)
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432

# ── Media / File storage ──────────────────────────────────────────────────────

# Django MEDIA_ROOT — where uploaded shipment documents are stored on disk.
# In production, point this to a persistent volume or use object storage (S3).
MEDIA_ROOT=/var/cargotrack/media

# ── M-Pesa (Safaricom Daraja 2.0) ────────────────────────────────────────────
# https://developer.safaricom.co.ke/
# Used for: Kenya STK Push (MPESA provider)

MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=replace-me
MPESA_CONSUMER_SECRET=replace-me
MPESA_SHORTCODE=174379
MPESA_PASSKEY=replace-me
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/webhooks/mpesa/

# ── Airtel Money ──────────────────────────────────────────────────────────────
# https://developers.airtel.africa/
# Used for: Uganda, Rwanda, Tanzania (AIRTEL provider)

AIRTEL_CLIENT_ID=replace-me
AIRTEL_CLIENT_SECRET=replace-me
AIRTEL_BASE_URL=https://openapi.airtel.africa

# ── MTN MoMo ──────────────────────────────────────────────────────────────────
# https://momodeveloper.mtn.com/
# Used for: Uganda, Rwanda (MTN provider)

MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_PRIMARY_KEY=replace-me
MTN_MOMO_USER_ID=replace-me
MTN_MOMO_API_KEY=replace-me
MTN_MOMO_CALLBACK_URL=https://your-domain.com/api/v1/payments/webhooks/mtn/

# ── Flutterwave ───────────────────────────────────────────────────────────────
# https://developer.flutterwave.com/
# Used for: Pan-Africa card & mobile money (FLUTTERWAVE provider)

FLUTTERWAVE_SECRET_KEY=replace-me
FLUTTERWAVE_PUBLIC_KEY=replace-me
FLUTTERWAVE_WEBHOOK_HASH=replace-me

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://stripe.com/docs/
# Used for: International card payments (STRIPE provider)

STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_PUBLISHABLE_KEY=pk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me

# ── Pesapal ───────────────────────────────────────────────────────────────────
# https://developer.pesapal.com/
# Used for: Multi-channel payments across East Africa (PESAPAL provider)

PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=replace-me
PESAPAL_CONSUMER_SECRET=replace-me
PESAPAL_CALLBACK_URL=https://your-domain.com/api/v1/payments/webhooks/pesapal/

# ── Expo Push Notifications ───────────────────────────────────────────────────
# https://expo.dev/accounts/[username]/projects/[slug]
# Used by the mobile app to send push notifications via Expo Push API.

EXPO_ACCESS_TOKEN=replace-me
