# CargoTrack frontend environment variables
# Copy to .env.local and fill in values before running locally.
# Never commit .env.local to version control.

# Base URL of the Django API server.
# In development, you can leave this as-is and rely on the Vite proxy
# (configured in vite.config.ts) by setting this to an empty string,
# or point directly at the Django dev server.
VITE_API_URL=http://localhost:8000
