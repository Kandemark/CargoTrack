{
  "title": "CargoTrack — Fleet Operations",
  "uid": "cargotrack-fleet-ops",
  "tags": ["cargotrack", "fleet", "logistics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Active Drivers by Status",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "count by (status) (fleet_drivers_total)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Truck Fleet Utilization (%)",
      "type": "gauge",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "sum(fleet_trucks_active_total) / sum(fleet_trucks_total) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 75}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Shipments by Status (last 24h)",
      "type": "barchart",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "count by (status) (shipments_total)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Shipment Transit Time (hours) — P50 / P95",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(shipment_transit_time_hours_bucket[24h])) by (corridor, le))",
          "legendFormat": "{{corridor}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(shipment_transit_time_hours_bucket[24h])) by (corridor, le))",
          "legendFormat": "{{corridor}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {"fillOpacity": 10, "lineWidth": 2}
        }
      }
    },
    {
      "id": 5,
      "title": "Border Crossing Delays (hours avg)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "avg by (border) (border_crossing_delay_hours)",
          "legendFormat": "{{border}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {"fillOpacity": 15, "lineWidth": 2}
        }
      }
    },
    {
      "id": 6,
      "title": "GPS Positions / Second",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "rate(gps_ingest_positions_total[1m])",
          "legendFormat": "positions/s"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "cps", "custom": {"fillOpacity": 20, "lineWidth": 2}}
      }
    },
    {
      "id": 7,
      "title": "Geofence Events / Min",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(gps_ingest_geofence_events_total[1m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "cpm", "custom": {"fillOpacity": 20, "lineWidth": 2}}
      }
    },
    {
      "id": 8,
      "title": "Alert Notifications Sent (by channel)",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(notification_sent_total[5m])) by (channel)",
          "legendFormat": "{{channel}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "cpm", "custom": {"fillOpacity": 15, "lineWidth": 2}}
      }
    }
  ]
}
