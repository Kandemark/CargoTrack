{
  "name": "@cargotrack/api-client",
  "version": "1.0.0",
  "description": "Typed API client for the CargoTrack logistics backbone — REST, WebSocket, and ML predictions",
  "license": "Proprietary",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./predictions": {
      "types": "./dist/predictions.d.ts",
      "import": "./dist/predictions.mjs",
      "require": "./dist/predictions.js"
    },
    "./ws": {
      "types": "./dist/ws.d.ts",
      "import": "./dist/ws.mjs",
      "require": "./dist/ws.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/predictions.ts src/ws.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/predictions.ts src/ws.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "axios": "^1.0.0"
  },
  "dependencies": {
    "@cargotrack/shared-types": "*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["cargotrack", "logistics", "freight", "api-client", "east-africa"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Kandemark/CargoTrack",
    "directory": "libs/api-client"
  }
}
